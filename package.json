{
  "name": "focus-roast",
  "version": "0.1.0",
  "description": "Cross-browser extension that scans your tabs and lets Gemini rate (and gently roast) your focus.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:firefox": "npm run build && node scripts/build-firefox.mjs",
    "typecheck": "tsc -b --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "knip": "knip",
    "check:version": "node scripts/check-version.mjs",
    "check:size": "node scripts/check-bundle-size.mjs",
    "lint:ext": "addons-linter dist-firefox",
    "preview": "vite preview"
  },
  "dependencies": {
    "chart.js": "^4.4.4",
    "react": "^18.3.1",
    "react-chartjs-2": "^5.2.0",
    "react-dom": "^18.3.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.0.0-beta.28",
    "@eslint/js": "^9.39.4",
    "addons-linter": "^7.20.0",
    "@types/chrome": "^0.0.270",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^9.1.2",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.26",
    "globals": "^15.15.0",
    "knip": "^5.88.1",
    "prettier": "^3.9.4",
    "typescript": "^5.6.2",
    "typescript-eslint": "^8.62.1",
    "vite": "^5.4.6"
  }
}
